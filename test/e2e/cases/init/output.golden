name: myproj
depend: standard-library
        standard-library-classes
        standard-library-meta
include: .
=== file: proj/pagda.nix ===
{ agdaPackages }: with agdaPackages; rec {

  myproj = mkDerivation {
    pname = "myproj";
    version = "0.1";
    src = ./.;
    meta = { };
    libraryFile = "myproj.agda-lib";
    buildInputs = [
      standard-library
      standard-library-classes
      standard-library-meta
    ];
  };

  default = myproj;
}
